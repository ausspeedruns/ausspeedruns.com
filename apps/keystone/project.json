{
	"name": "keystone",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/keystone",
	"projectType": "application",
	"targets": {
		"build": {
			"executor": "@ausspeedruns.com/keystone-plugin:build",
			"options": {
				"root": "apps/keystone",
				"outputPath": "dist/apps/keystone"
			}
		},
		"serve": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "apps/keystone",
				"commands": ["pnpm azurite-blob -l ./azurite --blobPort 9999", "pnpm keystone dev"],
				"parallel": true
			},
			"configurations": {
				"production": {
					"command": "pnpm keystone start"
				}
			}
		},
		"container": {
			"executor": "@nx-tools/nx-container:build",
			"options": {
				"engine": "docker",
				"tags": ["ausrunswebsitecontainersregistry.azurecr.io/ausruns/keystone:latest"],
				"file": "./apps/keystone/Dockerfile"
			},
			"dependsOn": ["build"]
		},
		"container-push": {
			"executor": "@nx-tools/nx-container:build",
			"options": {
				"engine": "docker",
				"push": true,
				"tags": ["ausrunswebsitecontainersregistry.azurecr.io/ausruns/keystone:latest"],
				"file": "./apps/keystone/Dockerfile"
			},
			"dependsOn": ["build"]
		},
		"seed": {
			"command": "pnpm keystone --seed-data"
		}
	},
	"tags": []
}
